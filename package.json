{
  "name": "sync-service",
  "version": "1.0.0",
  "description": "CQRS read-model microservice — consumes data.* events from RabbitMQ and projects them into MongoDB. Queried by the gateway via internal HTTPS.",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --accept-data-loss --skip-generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "amqplib": "^0.10.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^4.18.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/amqplib": "^0.10.1",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.0.0"
  }
}
